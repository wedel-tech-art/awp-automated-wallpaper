            'gtk_theme': new_gtk_theme,
            'icon_theme': new_icon_theme,
            'cursor_theme': new_cursor_theme,
            'wm_theme': new_gtk_theme
        }
    
    def _copy_to_preset(self, icon_path, ws_num):
        """Copy icon to preset folder as ws{N}.png."""
        if not icon_path or not os.path.exists(icon_path):
            return False
        
        selected_preset = self.preset_combo.currentData()
        preset_path = os.path.join(self.presets_dir, selected_preset)
        
        os.makedirs(preset_path, exist_ok=True)
        
        target_path = os.path.join(preset_path, f"ws{ws_num}.png")
        
        try:
            shutil.copy2(icon_path, target_path)
            _printer.info(f"Copied to preset: {target_path}", backend="baker")
            return True
        except Exception as e:
            _printer.error(f"Failed to copy to preset: {e}", backend="baker")
            return False
    
    def _fool_bake(self):
        """Fool Bake - Pure theme baking without workspace operations."""
        hex_color = self.hex_input.text().strip()
        if not hex_color.startswith('#') or len(hex_color) != 7:
            QMessageBox.warning(self, "Invalid Color", 
                "Please enter a valid hex color (e.g., #b3004c)")
            return
        
        gtk_preset = self.gtk_combo.currentText().lower()
        icon_preset = self.icon_combo.currentText().lower()
        cursor_preset = self.cursor_combo.currentText().lower()
        template_name = self.template_combo.currentData()
        
        self.bake_btn.setEnabled(False)
        self.bake_btn.setText("⏳ Fool Baking...")
        self.statusBar().showMessage("Fool Baking...")
        QApplication.processEvents()
        
        try:
            results = []
            errors = []
            
            _printer.info(f"Fool Bake: Baking themes with color {hex_color}", backend="baker")
            _printer.info(f"  GTK: {gtk_preset}, Icons: {icon_preset}, Cursors: {cursor_preset}", backend="baker")
            
            icon_path = generate_icon_from_svg(hex_color, template_name)
            
            if not icon_path:
                errors.append("Failed to generate icon (rsvg-convert missing?)")
                QMessageBox.warning(self, "Error", "Failed to generate icon. Make sure rsvg-convert is installed.")
                return
            
            if gtk_preset:
                try:
                    theme = bake_awp_theme(hex_color, icon=icon_path, preset=gtk_preset)
                    if theme:
                        results.append(f"✅ GTK Theme: {theme}")
                except Exception as e:
                    errors.append(f"GTK Theme: {e}")
            
            if icon_preset:
                try:
                    icon_result = bake_awp_icon(hex_color, icon=icon_path, preset=icon_preset)
                    if icon_result:
                        results.append(f"✅ Icon Theme: {icon_result}")
                except Exception as e:
                    errors.append(f"Icon Theme: {e}")
            
            if cursor_preset:
                try:
                    cursor_result = bake_awp_cursor(hex_color, icon=icon_path, preset=cursor_preset)
                    if cursor_result:
                        results.append(f"✅ Cursor Theme: {cursor_result}")
                except Exception as e:
                    errors.append(f"Cursor Theme: {e}")
            
            cleanup_temp_icon(icon_path)
            
            if self.symlink_cb.isChecked() and self.symlink_cb.isEnabled():
                _printer.info("Recreating symlinks...", backend="baker")
                if run_awp_start(self.current_preset):
                    results.append("✅ Symlinks recreated")
                else:
                    errors.append("Failed to recreate symlinks")
            
            msg = "🛠️ Fool Bake Complete!\n\n"
            msg += "Themes baked with folder.png (workspace icon)\n"
            msg += "No INI updates, no preset copies, no workspace changes.\n\n"
            msg += "\n".join(results)
            
            if errors:
                msg += "\n\n⚠️ Errors:\n" + "\n".join(errors)
            
            self.statusBar().showMessage("Fool Bake Complete!")
            QMessageBox.information(self, "Fool Bake Complete", msg)
            
        except Exception as e:
            self.statusBar().showMessage("Fool Bake Failed!")
            QMessageBox.critical(self, "Error", f"Fool Bake failed:\n\n{str(e)}")
        
        finally:
            self.bake_btn.setEnabled(True)
            self.bake_btn.setText("🔥 Bake && Update")
    
    def _regenerate_all_themes(self):
        """Regenerate ALL themes from the INI file."""
        selected_preset = self.preset_combo.currentData()
        ini_path = self._get_preset_ini_path(selected_preset)
        
        if not os.path.exists(ini_path):
            QMessageBox.warning(self, "Error", f"INI not found: {ini_path}")
            return
        
        # Build confirmation message
        confirm_msg = f"This will regenerate ALL themes for ALL workspaces in:\n\n"
        confirm_msg += f"{selected_preset}\n\n"
        confirm_msg += f"This includes:\n"
        confirm_msg += f"• GTK themes (with XFWM if applicable)\n"
        confirm_msg += f"• Icon themes\n"
        confirm_msg += f"• Cursor themes\n"
        confirm_msg += f"• Workspace icons (ws*.png)\n\n"
        
        if self.clean_cb.isChecked():
            confirm_msg += f"🧹 Clean Start is ENABLED:\n"
            confirm_msg += f"   • All existing awp themes will be REMOVED\n"
            confirm_msg += f"   • Then regenerated fresh\n\n"
        else:
            confirm_msg += f"🧹 Clean Start is DISABLED:\n"
            confirm_msg += f"   • Existing themes will be OVERWRITTEN\n"
            confirm_msg += f"   • (Cleaner to enable Clean Start)\n\n"
        
        confirm_msg += f"Proceed?"
        
        reply = QMessageBox.question(
            self,
            "Regenerate All Themes",
            confirm_msg,
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.Yes
        )
        
        if reply != QMessageBox.StandardButton.Yes:
            return
        
        self.bake_btn.setEnabled(False)
        self.bake_btn.setText("⏳ Regenerating...")
        self.progress_bar.setVisible(True)
        self.progress_bar.setRange(0, 100)
        self.progress_bar.setValue(0)
        self.progress_bar.setFormat("Regenerating... %p%")
        self.statusBar().showMessage(f"Regenerating all themes for {selected_preset}...")
        QApplication.processEvents()
        
        try:
            config = configparser.ConfigParser()
            config.read(ini_path)
            
            results = []
            errors = []
            
            # Step 1: Clean old themes if requested
            if self.clean_cb.isChecked():
                _printer.info("🧹 Cleaning old themes...", backend="baker")
                removed = clean_old_themes()
                if removed:
                    results.append(f"🧹 Removed {len(removed)} old themes")
                    for item in removed[:5]:  # Show first 5
                        results.append(f"   - {item}")
                    if len(removed) > 5:
                        results.append(f"   ... and {len(removed) - 5} more")
                else:
                    results.append("🧹 No old themes found to remove")
            
            # Get workspace count
            num_workspaces = 8
            if config.has_section('general') and config.has_option('general', 'workspaces'):
                try:
                    num_workspaces = int(config.get('general', 'workspaces'))
                except:
                    pass
            
            # Summary counters
            total_gtk = 0
            total_icons = 0
            total_cursors = 0
            total_ws_icons = 0
            total_steps = num_workspaces * 3  # GTK + Icons + Cursors per workspace
            processed = 0
            
            for i in range(1, num_workspaces + 1):
                section = f'ws{i}'
                if not config.has_section(section):
                    continue
                
                hex_color = config.get(section, 'icon_color', fallback='')
                if not hex_color or not hex_color.startswith('#'):
                    _printer.warning(f"WS{i}: No valid color, skipping", backend="baker")
                    continue
                
                # Get themes from INI
                gtk_theme = config.get(section, 'gtk_theme', fallback='awp-gtk-breeze-000000')
                icon_theme = config.get(section, 'icon_theme', fallback='awp-icons-mint-000000')
                cursor_theme = config.get(section, 'cursor_theme', fallback='awp-cursor-oxy-000000')
                
                # Extract presets using utility function
                gtk_preset = extract_preset_from_theme(gtk_theme, 'awp-gtk-')
                icon_preset = extract_preset_from_theme(icon_theme, 'awp-icons-')
                cursor_preset = extract_preset_from_theme(cursor_theme, 'awp-cursor-')
                
                # Fallbacks
                if not gtk_preset or gtk_preset not in THEME_PRESETS:
                    gtk_preset = 'breeze'
                if not icon_preset or icon_preset not in ICON_PRESETS:
                    icon_preset = 'mint'
                if not cursor_preset or cursor_preset not in CURSOR_PRESETS:
                    cursor_preset = 'oxy'
                
                _printer.info(f"Regenerating WS{i}: {hex_color} (GTK:{gtk_preset}, Icons:{icon_preset}, Cursors:{cursor_preset})", backend="baker")
                
                # Generate icon
                icon_path = generate_icon_from_svg(hex_color, 'awp')
                
                if not icon_path:
                    errors.append(f"WS{i}: Failed to generate icon")
                    continue
                
                # Bake themes
                try:
                    theme_result = bake_awp_theme(hex_color, icon_path, gtk_preset)
                    if theme_result:
                        total_gtk += 1
                except Exception as e:
                    errors.append(f"WS{i}: GTK/XFWM theme failed - {e}")
                processed += 1
                self.progress_bar.setValue(int((processed / total_steps) * 100))
                QApplication.processEvents()
                
                try:
                    icon_result = bake_awp_icon(hex_color, icon_path, icon_preset)
                    if icon_result:
                        total_icons += 1
                except Exception as e:
                    errors.append(f"WS{i}: Icon theme failed - {e}")
                processed += 1
                self.progress_bar.setValue(int((processed / total_steps) * 100))
                QApplication.processEvents()
                
                try:
                    cursor_result = bake_awp_cursor(hex_color, icon_path, cursor_preset)
                    if cursor_result:
                        total_cursors += 1
                except Exception as e:
                    errors.append(f"WS{i}: Cursor theme failed - {e}")
                processed += 1
                self.progress_bar.setValue(int((processed / total_steps) * 100))
                QApplication.processEvents()
                
                # Copy to preset
                if self._copy_to_preset(icon_path, i):
                    total_ws_icons += 1
                else:
                    errors.append(f"WS{i}: Failed to copy icon to preset")
                
                # Clean up
                cleanup_temp_icon(icon_path)
                
                # Add workspace summary
                results.append(f"WS{i}: {hex_color} → GTK+WM: {gtk_preset}, Icons: {icon_preset}, Cursors: {cursor_preset}")
            
            # Recreate symlinks if requested
            if self.symlink_cb.isChecked() and self.symlink_cb.isEnabled():
                _printer.info("Recreating symlinks...", backend="baker")
                if run_awp_start(self.current_preset):
                    results.append("✅ Symlinks recreated")
                else:
                    errors.append("Failed to recreate symlinks")
            
            self.progress_bar.setVisible(False)
            
            # Build summary message
            msg = "🔄 Regeneration Complete!\n\n"
            msg += f"📁 Preset: {selected_preset}\n"
            msg += f"📊 Summary:\n"
            msg += f"   • GTK themes (with XFWM): {total_gtk}\n"
            msg += f"   • Icon themes: {total_icons}\n"
            msg += f"   • Cursor themes: {total_cursors}\n"
            msg += f"   • Workspace icons: {total_ws_icons}\n\n"
            msg += "📋 Details:\n"
            msg += "\n".join(results)
            
            if errors:
                msg += "\n\n⚠️ Errors:\n" + "\n".join(errors)
            
            self.statusBar().showMessage("Regeneration complete!")
            QMessageBox.information(self, "Regeneration Complete", msg)
            
        except Exception as e:
            self.progress_bar.setVisible(False)
            self.statusBar().showMessage("Regeneration failed!")
            QMessageBox.critical(self, "Error", f"Regeneration failed:\n\n{str(e)}")
        
        finally:
            self.bake_btn.setEnabled(True)
            self.bake_btn.setText("🔥 Bake && Update")
    
    def bake_and_update(self):
        """Main bake and update function."""
        
        # Check if Regenerate is enabled
        if self.regenerate_cb.isChecked():
            self._regenerate_all_themes()
            return
        
        # Check if Fool Bake is enabled
        if self.fool_bake_cb.isChecked():
            self._fool_bake()
            return
        
        hex_color = self.hex_input.text().strip()
        if not hex_color.startswith('#') or len(hex_color) != 7:
            QMessageBox.warning(self, "Invalid Color", 
                "Please enter a valid hex color (e.g., #b3004c)")
            return
        
        # Get selected workspace
        ws_index = self.ws_combo.currentIndex()
        if ws_index < 0 or ws_index >= len(self.workspaces):
            QMessageBox.warning(self, "Error", "No workspace selected.")
            return
        
        ws = self.workspaces[ws_index]
        ws_num = ws['num']
        ws_name = ws['name']
        
        selected_preset = self.preset_combo.currentData()
        is_current_preset = selected_preset == self.current_preset
        ini_path = self._get_preset_ini_path(selected_preset)
        
        # Confirm with user
        confirm_msg = (
            f"Update workspace {ws_num} ({ws_name})?\n\n"
            f"Target Preset: {selected_preset} {'✓ Current' if is_current_preset else ''}\n"
            f"Current color: {ws.get('color', 'None')}\n"
            f"New color: {hex_color}\n\n"
            f"This will:\n"
            f"• Update the INI file (color + theme names)\n"
            f"• Bake GTK, Icon, and Cursor themes\n"
            f"• Copy ws{ws_num}.png to {selected_preset}/\n"
        )
        
        if is_current_preset and self.symlink_cb.isChecked():
            confirm_msg += f"• Recreate symlinks via awp_start.sh\n"
        elif not is_current_preset:
            confirm_msg += f"⚠️ Symlinks will NOT be recreated (different preset)\n"
        
        confirm_msg += f"\nProceed?"
        
        reply = QMessageBox.question(
            self,
            "Confirm Update",
            confirm_msg,
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.Yes
        )
        
        if reply != QMessageBox.StandardButton.Yes:
            return
        
        self.bake_btn.setEnabled(False)
        self.bake_btn.setText("⏳ Working...")
        self.progress_bar.setVisible(True)
        self.progress_bar.setRange(0, 100)
        self.progress_bar.setValue(0)
        self.progress_bar.setFormat("Baking... %p%")
        self.statusBar().showMessage(f"Baking WS{ws_num} to {selected_preset}...")
        QApplication.processEvents()
        
        try:
            results = []
            errors = []
            
            gtk_preset = self.gtk_combo.currentText().lower()
            icon_preset = self.icon_combo.currentText().lower()
            cursor_preset = self.cursor_combo.currentText().lower()
            template_name = self.template_combo.currentData()
            
            # Step 1: Update color in the target preset's INI
            self.progress_bar.setValue(10)
            QApplication.processEvents()
            _printer.info(f"Updating INI for WS{ws_num} in {selected_preset}", backend="baker")
            if self._update_ini_color_direct(ini_path, ws_num, hex_color):
                results.append(f"✅ INI color updated: {selected_preset}/ws{ws_num}.icon_color = {hex_color}")
            else:
                errors.append("Failed to update INI color")
            
            # Step 2: Generate icon
            self.progress_bar.setValue(20)
            QApplication.processEvents()
            icon_path = generate_icon_from_svg(hex_color, template_name)
            
            if not icon_path:
                errors.append("Failed to generate icon (rsvg-convert missing?)")
                QMessageBox.warning(self, "Error", "Failed to generate icon. Make sure rsvg-convert is installed.")
                return
            
            # Step 3: Bake themes
            self.progress_bar.setValue(40)
            QApplication.processEvents()
            _printer.info(f"Baking themes for WS{ws_num} with color {hex_color}", backend="baker")
            
            if gtk_preset:
                try:
                    theme = bake_awp_theme(hex_color, icon=icon_path, preset=gtk_preset)
                    if theme:
                        results.append(f"✅ GTK Theme: {theme}")
                except Exception as e:
                    errors.append(f"GTK Theme: {e}")
            
            self.progress_bar.setValue(60)
            QApplication.processEvents()
            
            if icon_preset:
                try:
                    icon_result = bake_awp_icon(hex_color, icon=icon_path, preset=icon_preset)
                    if icon_result:
                        results.append(f"✅ Icon Theme: {icon_result}")
                except Exception as e:
                    errors.append(f"Icon Theme: {e}")
            
            self.progress_bar.setValue(80)
            QApplication.processEvents()
            
            if cursor_preset:
                try:
                    cursor_result = bake_awp_cursor(hex_color, icon=icon_path, preset=cursor_preset)
                    if cursor_result:
                        results.append(f"✅ Cursor Theme: {cursor_result}")
                except Exception as e:
                    errors.append(f"Cursor Theme: {e}")
            
            # Step 4: Update theme fields in the target preset's INI
            self.progress_bar.setValue(90)
            QApplication.processEvents()
            theme_updates = self._update_ini_themes_direct(ini_path, ws_num, hex_color, gtk_preset, icon_preset, cursor_preset)
            if theme_updates:
                results.append(f"✅ INI themes updated in {selected_preset}:")
                results.append(f"   gtk_theme = {theme_updates['gtk_theme']}")
                results.append(f"   icon_theme = {theme_updates['icon_theme']}")
                results.append(f"   cursor_theme = {theme_updates['cursor_theme']}")
                results.append(f"   wm_theme = {theme_updates['wm_theme']}")
            else:
                errors.append("Failed to update INI themes")
            
            # Step 5: Copy to preset folder
            if icon_path and os.path.exists(icon_path):
                if self._copy_to_preset(icon_path, ws_num):
                    results.append(f"✅ Preset icon: {selected_preset}/ws{ws_num}.png")
                else:
                    errors.append("Failed to copy icon to preset")
            
            # Step 6: Clean up temp icon
            cleanup_temp_icon(icon_path)
            
            # Step 7: Recreate symlinks (only if selected preset is current)
            self.progress_bar.setValue(100)
            QApplication.processEvents()
            if is_current_preset and self.symlink_cb.isChecked():
                _printer.info("Recreating symlinks...", backend="baker")
                if run_awp_start(self.current_preset):
                    results.append("✅ Symlinks recreated")
                else:
                    errors.append("Failed to recreate symlinks")
            elif not is_current_preset:
                results.append("ℹ️ Skipped symlinks (target preset is not current)")
            
            self.progress_bar.setVisible(False)
            
            # Step 8: Reload workspaces from the updated INI
            self.workspaces, self.num_workspaces = self._get_workspaces_from_ini(ini_path)
            self._update_workspace_combo()
            
            # Show results
            msg = f"✅ Workspace {ws_num} ({ws_name}) updated successfully!\n\n"
            msg += "\n".join(results)
            
            if errors:
                msg += "\n\n⚠️ Warnings/Errors:\n" + "\n".join(errors)
            
            self.statusBar().showMessage(f"WS{ws_num} updated to {selected_preset}!")
            QMessageBox.information(self, "Success", msg)
            
        except Exception as e:
            self.progress_bar.setVisible(False)
            self.statusBar().showMessage("Update failed!")
            QMessageBox.critical(self, "Error", f"Failed to update workspace:\n\n{str(e)}")
        
        finally:
            self.bake_btn.setEnabled(True)
            self.bake_btn.setText("🔥 Bake && Update")


