    def _update_ini_color_direct(self, ini_path, ws_num, new_color):
        """Update color in a specific INI file directly."""
        if not os.path.exists(ini_path):
            _printer.error(f"INI file not found: {ini_path}", backend="baker")
            return False
        
        config = configparser.ConfigParser()
        config.read(ini_path)
        
        section = f'ws{ws_num}'
        if not config.has_section(section):
            config.add_section(section)
        
        config.set(section, 'icon_color', new_color)
        
        if config.has_option(section, 'color_variable'):
            clean_hex = new_color.lstrip('#')
            config.set(section, 'color_variable', f'ws{ws_num}_color')
        
        with open(ini_path, 'w') as f:
            config.write(f)
        
        _printer.info(f"Updated INI: {ini_path} ws{ws_num}.icon_color = {new_color}", backend="baker")
        return True
    
    def _update_ini_themes_direct(self, ini_path, ws_num, hex_color, gtk_preset, icon_preset, cursor_preset):
        """Update theme fields in a specific INI file directly."""
        if not os.path.exists(ini_path):
            _printer.error(f"INI file not found: {ini_path}", backend="baker")
            return None
        
        config = configparser.ConfigParser()
        config.read(ini_path)
        
        section = f'ws{ws_num}'
        if not config.has_section(section):
            config.add_section(section)
        
        clean_hex = hex_color.lstrip('#')
        
        new_gtk_theme = f"awp-gtk-{gtk_preset}-{clean_hex}"
        new_icon_theme = f"awp-icons-{icon_preset}-{clean_hex}"
        new_cursor_theme = f"awp-cursor-{cursor_preset}-{clean_hex}"
        
        config.set(section, 'gtk_theme', new_gtk_theme)
        config.set(section, 'icon_theme', new_icon_theme)
        config.set(section, 'cursor_theme', new_cursor_theme)
        config.set(section, 'wm_theme', new_gtk_theme)
        
        with open(ini_path, 'w') as f:
            config.write(f)
        
        _printer.info(f"Updated INI themes in {ini_path} for WS{ws_num}:", backend="baker")
        _printer.info(f"  gtk_theme = {new_gtk_theme}", backend="baker")
        _printer.info(f"  icon_theme = {new_icon_theme}", backend="baker")
        _printer.info(f"  cursor_theme = {new_cursor_theme}", backend="baker")
        _printer.info(f"  wm_theme = {new_gtk_theme}", backend="baker")
        
