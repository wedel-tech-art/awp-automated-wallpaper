    def _get_preset_from_shm(self):
        """Read the current preset name from RAM-based session state."""
        shm_path = "/dev/shm/awp_active_preset"
        if os.path.exists(shm_path):
            try:
                with open(shm_path, 'r') as f:
                    return f.read().strip()
            except Exception as e:
                _printer.warning(f"Failed to read preset from SHM: {e}", backend="baker")
        return None
    
    def _get_available_presets(self):
        """Get list of available presets from the presets directory."""
        presets = []
        if os.path.exists(self.presets_dir):
            for item in os.listdir(self.presets_dir):
                item_path = os.path.join(self.presets_dir, item)
                if os.path.isdir(item_path) and not item.startswith('.'):
                    if os.path.exists(os.path.join(item_path, f"{item}.ini")) or \
                       any(f.startswith('ws') and f.endswith('.png') for f in os.listdir(item_path)):
                        presets.append(item)
        return sorted(presets)
    
    def _get_preset_ini_path(self, preset_name):
        """Get the path to a preset's INI file."""
        preset_path = os.path.join(self.presets_dir, preset_name)
        ini_path = os.path.join(preset_path, f"{preset_name}.ini")
        return ini_path
    
    def _get_workspaces_from_ini(self, ini_path):
        """Get workspaces from a specific INI file."""
        if not os.path.exists(ini_path):
            _printer.warning(f"INI file not found: {ini_path}", backend="baker")
            return [], 8
        
        config = configparser.ConfigParser()
        config.read(ini_path)
        
        workspaces = []
        num_workspaces = 8
        
        # Try to get workspaces count from general section
        if config.has_section('general') and config.has_option('general', 'workspaces'):
            try:
                num_workspaces = int(config.get('general', 'workspaces'))
            except:
                pass
        
        for i in range(1, num_workspaces + 1):
            section = f'ws{i}'
            if config.has_section(section):
                folder = config.get(section, 'folder', fallback=f'ws{i}')
                color = config.get(section, 'icon_color', fallback='#888888')
                
                if folder:
                    name = os.path.basename(os.path.normpath(folder))
                    if not name or name == '.':
                        name = f'ws{i}'
                else:
                    name = f'ws{i}'
                
                workspaces.append({
                    'num': i,
                    'name': name,
                    'folder': folder,
                    'color': color
                })
        
        return workspaces, num_workspaces
    
    def _update_workspace_combo(self):
        """Update the workspace combo box with current workspaces."""
        self.ws_combo.clear()
        for ws in self.workspaces:
            color = ws.get('color', '#888888')
            self.ws_combo.addItem(
                f"WS{ws['num']}: {ws['name']} [{color}]", 
                ws['num']
            )
        if self.ws_combo.count() > 0:
            self.ws_combo.setCurrentIndex(0)
            self.on_ws_selected(0)
    
    def on_preset_changed(self, index):
        """Update when preset selection changes."""
        if index < 0:
            return
        
        selected_preset = self.preset_combo.currentData()
        is_current = selected_preset == self.current_preset
        
        # Reload workspaces from the selected preset's INI
        ini_path = self._get_preset_ini_path(selected_preset)
        if os.path.exists(ini_path):
            self.current_ini_path = ini_path
            self.workspaces, self.num_workspaces = self._get_workspaces_from_ini(ini_path)
            self._update_workspace_combo()
            _printer.info(f"Loaded workspaces from: {ini_path}", backend="baker")
            self.statusBar().showMessage(f"Loaded preset: {selected_preset}")
        else:
            _printer.warning(f"INI file not found: {ini_path}", backend="baker")
            self.statusBar().showMessage(f"INI not found: {selected_preset}")
        
        self.update_symlink_state()
        self.statusBar().showMessage(f"Selected preset: {selected_preset} {'(current)' if is_current else ''}")
    
    def update_symlink_state(self):
        """Enable/disable symlink checkbox and style its text."""
        selected_preset = self.preset_combo.currentData()
        is_current = (selected_preset == self.current_preset)
        is_fool_mode = self.fool_bake_cb.isChecked()
        
        # Only Fool Bake disables symlinks
        can_use_symlinks = is_current and not is_fool_mode
        
        self.symlink_cb.setEnabled(can_use_symlinks)
        
        color = "#ddd" if can_use_symlinks else "#777"
        self.symlink_cb.setStyleSheet(f"color: {color}; font-size: 12px;")
            
        if not can_use_symlinks:
            self.symlink_cb.setChecked(False)
            if is_fool_mode:
                self.symlink_cb.setToolTip("Symlinks disabled during Fool Bake")
            else:
                self.symlink_cb.setToolTip("Symlinks can only be recreated for the current DE preset")
        else:
            self.symlink_cb.setToolTip("Run awp_start.sh to recreate symlinks")
    
    def update_checkbox_state(self):
        """Update checkbox states and enable/disable based on combinations."""
        
        fool_bake = self.fool_bake_cb.isChecked()
        regenerate = self.regenerate_cb.isChecked()
        clean = self.clean_cb.isChecked()
        
        # --- Rule 1: Fool Bake overrides everything ---
        if fool_bake:
            self.regenerate_cb.setEnabled(False)
            self.regenerate_cb.setChecked(False)
            self.clean_cb.setEnabled(False)
            self.clean_cb.setChecked(False)
            self.symlink_cb.setEnabled(False)
            self.symlink_cb.setChecked(False)
            self.bake_btn.setText("🔥 Fool Bake")
            self.statusBar().showMessage("Fool Bake mode: themes only")
            return
        
        # --- Rule 2: Not Fool Bake - enable things normally ---
        self.regenerate_cb.setEnabled(True)
        self.symlink_cb.setEnabled(True)
        
        # Clean Start only works with Regenerate
        self.clean_cb.setEnabled(regenerate)
        if not regenerate:
            self.clean_cb.setChecked(False)
        
        # --- Rule 3: Update button text ---
        if regenerate:
            if clean:
                self.bake_btn.setText("🔥 Clean && Regenerate")
                self.statusBar().showMessage("Clean Start + Regenerate All (fresh rebuild)")
            else:
                self.bake_btn.setText("🔥 Regenerate All")
                self.statusBar().showMessage("Regenerate All (rebuild from INI)")
        else:
            self.bake_btn.setText("🔥 Bake && Update")
            self.statusBar().showMessage("Ready")
        
        # --- Rule 4: Update symlink state ---
        self.update_symlink_state()
    
    def on_clean_toggled(self, checked):
        """Handle Clean Start checkbox toggling."""
        if checked and not self.regenerate_cb.isChecked():
            # Auto-enable Regenerate if Clean is checked
            self.regenerate_cb.setChecked(True)
            self.regenerate_cb.setEnabled(True)
            self.statusBar().showMessage("Clean Start requires Regenerate - auto-enabled")
        
        # Update checkbox state
        self.update_checkbox_state()
    
